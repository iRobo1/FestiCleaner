# Database
DATABASE_URL=sqlite:///./robot_data.db

# Camera
# 1920x1080 = Full HD
CAMERA_ID=0
CAMERA_WIDTH=1920
CAMERA_HEIGHT=1080
CAMERA_JPEG_QUALITY=85

# Robot
GRID_SIZE=20
CELL_SIZE=0.5

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Arduino — serial (legacy, unused while running fake_arduino.py)
ARDUINO_PORT=/dev/ttyUSB0
ARDUINO_BAUDRATE=9600

# Arduino — Socket.IO bridge.
# When ARDUINO_HOST is set, the backend opens a long-lived Socket.IO client
# to the device's WebUI brick and emits "power" events on /api/robot/shutdown
# and /api/robot/start. If unset, the backend runs standalone (soft shutdown
# only — no signal is sent to the device).
ARDUINO_HOST=
ARDUINO_WEBUI_PORT=7000
