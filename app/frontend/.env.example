# Copy to .env.local and edit, then restart `bun run dev`.
#
# Hostname / IP of the Arduino UNO Q on your LAN. When set, the dashboard's
# Live panel embeds http://<host>:4912/embed (the on-board camera stream from
# the video_object_detection brick) instead of the ASCII telemetry fallback.
#
# Either an mDNS name or a raw IP works:
#   VITE_BOARD_HOST=festicleaner.local
#   VITE_BOARD_HOST=192.168.1.42
VITE_BOARD_HOST=
